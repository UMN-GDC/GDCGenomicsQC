        umap_sample=OUT_DIR / "01-globalAncestry" / "umap_sample.csv",
        rfmix_global=lambda wildcards: OUT_DIR / "02-localAncestry" / "ancestry_full.txt" if uses_rfmix() else [],


rule run_classifyAncestry:
    threads: 1
    resources:
        nodes=1,
        mem_mb=4000,
        runtime=420,
    input:
        rfmix=lambda wildcards: OUT_DIR / "02-localAncestry" / "ancestry_full.txt" if uses_rfmix() else [],
        classification_probability=OUT_DIR / "01-globalAncestry" / "classificationProbabilities.tsv",


rule run_ancestryQC:
    threads: 1
    resources:
        nodes=1,
        mem_mb=4000,
        runtime=420,  # 1 week
    input:
        lambda wildcards: (
            expand(
                OUT_DIR / "{ANCESTRY}" / "f1_{CHR}.pgen",
                ANCESTRY=get_ancestries(wildcards),
                CHR=CHROMOSOMES,
            )
            if INPUT_IS_PER_CHROMOSOME
            else expand(
                OUT_DIR / "{ANCESTRY}" / "f1.b38.pgen",
                ANCESTRY=get_ancestries(wildcards),
            )
        ),
        lambda wildcards: (
            expand(
                OUT_DIR / "{ANCESTRY}" / "f1.f2_{CHR}.pgen",
                ANCESTRY=get_ancestries(wildcards),
                CHR=CHROMOSOMES,
            )
            if INPUT_IS_PER_CHROMOSOME
            else expand(
                OUT_DIR / "{ANCESTRY}" / "f1.b38.f2.pgen",
                ANCESTRY=get_ancestries(wildcards),
            )
        ),


rule run_relatedness:
    threads: 1
    resources:
        nodes=1,
        mem_mb=4000,
        runtime=420,  # 1 week
    input:
        OUT_DIR / "full" / "f1.b38.ldpruned.unrelated.pgen",
        lambda wildcards: expand(
            OUT_DIR / "{ANCESTRY}" / "f1.b38.ldpruned.unrelated.pgen",
            ANCESTRY=get_ancestries(wildcards),
        ),


rule run_rfmix:
    threads: 1
    resources:
        nodes=1,
        mem_mb=4000,
        runtime=420,
    input:
        lambda wildcards: (
            expand(OUT_DIR / "02-localAncestry" / "chr{CHR}.phased.vcf.gz", CHR=LOCAL_ANCESTRY_CHROMOSOMES) +
            expand(OUT_DIR / "02-localAncestry" / "chr{CHR}.lai.msp.tsv", CHR=LOCAL_ANCESTRY_CHROMOSOMES)
        ) if uses_rfmix() else [],
        ancestry=lambda wildcards: [OUT_DIR / "02-localAncestry" / "ancestry_full.txt"] if uses_rfmix() else [],


rule run_qcPlots:
    threads: 1
    resources:
        nodes=1,
        mem_mb=4000,
        runtime=60,
    input:
        lambda wildcards: (
            [OUT_DIR / "full" / "figures" / "smiss.svg",
             OUT_DIR / "full" / "figures" / "vmiss.svg"]
            if not input_is_per_chromosome() else []
        ),
        lambda wildcards: (
            [OUT_DIR / "full" / "figures" / "hwe_histogram.svg"]
            if not input_is_per_chromosome() else []
        ),
        lambda wildcards: (
            [OUT_DIR / "full" / "figures" / "het_distribution.svg"]
            if not input_is_per_chromosome() else []
        ),
        lambda wildcards: (
            [OUT_DIR / "full" / "figures" / "relatedness_histogram.svg"]
            if not input_is_per_chromosome() else []
        ),
        lambda wildcards: (
            [OUT_DIR / "full" / "figures" / "pcair_pcs.svg"]
            if config.get("internalPCA", {}).get("method", "plink2") in ["pcair", "both"]
            else []
        ),
        OUT_DIR / "01-globalAncestry" / f"classificationProbability_stacked_{ANCESTRY_MODEL}.svg",
        OUT_DIR / "01-globalAncestry" / "ancestry_classification_space.svg",


rule run_simulatePhenotype:
    threads: 1
    resources:
        nodes=1,
        mem_mb=4000,
        runtime=420,
    input:
        lambda wildcards: (
            lambda sim_cfg, ancs: expand(
                OUT_DIR / "{ancestry}" / "simulations" / "{sim_name}" / "simulated.bed",
                ancestry=ancs,
                sim_name=[s["name"] for s in sim_cfg.get("simulations", [])],
            )
        )(config.get("phenotypeSimulation", {}), config.get("phenotypeSimulation", {}).get("ancestries", [])) if (
            config.get("phenotypeSimulation", {}).get("enabled", False)
            and config.get("phenotypeSimulation", {}).get("ancestries", [])
            and config.get("phenotypeSimulation", {}).get("simulations", [])
        ) else [],



