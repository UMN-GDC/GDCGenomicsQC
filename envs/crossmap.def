Bootstrap: docker
From: mambaorg/micromamba:latest

%arguments
    ENV_NAME=crossmap

%environment
    export MAMBA_ROOT_PREFIX=/opt/conda
    export PATH="/opt/conda/envs/{{ ENV_NAME }}/bin:$PATH"
    export LC_ALL=C.UTF-8

%files
    crossmap.yml /app/crossmap.yml

%post
    /usr/bin/micromamba create -y -n {{ ENV_NAME }} -f /app/crossmap.yml
    /usr/bin/micromamba clean --all -y
