#!/bin/bash
# Wrapper for snakemake that uses GDC Genomics QC defaults
# Usage: gdcgenomicsqc [SNAKEMAKE_ARGS...]
#
# This wrapper adds:
#   --profile profiles/hpc
#   --snakefile workflow/Snakefile
# Users only need to specify --configfile

WORKFLOW_DIR=/scratch.global/coffm049/GDCGenomicsQC

exec snakemake --directory "$WORKFLOW_DIR" --profile "$WORKFLOW_DIR/profiles/hpc" --snakefile "$WORKFLOW_DIR/workflow/Snakefile" --rerun-incomplete "$@"
