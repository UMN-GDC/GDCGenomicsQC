#%Module######################################################################
#
#     GDC Genomics QC Pipeline module file
#     Sets up singularity image cache for offline use
#

proc ModulesHelp { } {
    puts stderr "\tThis module loads the GDC Genomics QC Pipeline.\n\tIt sets up the singularity image cache for offline use."
}

module load singularity

set basedir /scratch.global/coffm049/GDCGenomicsQC/envs/gdcgenomicsqc/1.0.0
prepend-path PATH $basedir/bin
setenv SINGULARITY_CACHEDIR /scratch.global/GDC/singularityimages
setenv SNAKEMAKE_SINGULARITY_PREFIX /scratch.global/GDC/singularityimages