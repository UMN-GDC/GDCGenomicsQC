rule all:
    threads: 1
    resources:
        nodes=1,
        mem_mb=1000,
        runtime=420,
    input:
        lambda wildcards: expand(
            OUT_DIR / "{ANCESTRY}" / "initialFilter_{CHR}.pgen",
            ANCESTRY=get_ancestries(wildcards),
            CHR=CHROMOSOMES,
        ),
        lambda wildcards: expand(
            OUT_DIR / "{ANCESTRY}" / "initialFilter.pgen",
            ANCESTRY=get_ancestries(wildcards),
        ),
        lambda wildcards: expand(
            OUT_DIR / "{ANCESTRY}" / "standardFilter.pgen",
            ANCESTRY=get_ancestries(wildcards),
        ),
        #lambda wildcards: expand(OUT_DIR / "{ANCESTRY}" / "unrelated.pgen", ANCESTRY= get_ancestries(wildcards)),
        OUT_DIR / "full" / "standardFilter.pgen",
        expand(OUT_DIR / "02-localAncestry" / "chr{CHR}.phased.vcf.gz", CHR=CHROMOSOMES),
        expand(OUT_DIR / "02-localAncestry" / "chr{CHR}.lai.msp.tsv", CHR=CHROMOSOMES),
        OUT_DIR / "02-localAncestry" / "ancestry_full.txt",
        OUT_DIR / "01-globalAncestry" / "posterior_probabilities.tsv",
        OUT_DIR
        / "01-globalAncestry"
        / f"posterior_probability_stacked_{ANCESTRY_MODEL}.svg",
        lambda wildcards: expand(
            OUT_DIR / "{ANCESTRY}" / "pcair_pcaobj.RDS",
            ANCESTRY=get_ancestries(wildcards),
        ),
        lambda wildcards: expand(
            OUT_DIR / "{ANCESTRY}" / "pcrelate_kinship.RDS",
            ANCESTRY=get_ancestries(wildcards),
        ),
        lambda wildcards: expand(
            OUT_DIR / "{ANCESTRY}" / "figures" / "pcair_pcs.svg",
            ANCESTRY=get_ancestries(wildcards),
        ),
        lambda wildcards: expand(
            OUT_DIR / "{ANCESTRY}" / "pcair_coordinates.tsv",
            ANCESTRY=get_ancestries(wildcards),
        ),
        OUT_DIR / "full" / "pcair_pcaobj.RDS",
        OUT_DIR / "full" / "pcrelate_kinship.RDS",
        OUT_DIR / "full" / "figures" / "pcair_pcs.svg",
        OUT_DIR / "full" / "pcair_coordinates.tsv",
        lambda wildcards: (
            expand(
                OUT_DIR
                / "{subset}"
                / "03-snpHeritability"
                / config["snpHerit"]["out"],
                subset=["full"] + get_ancestries(wildcards),
            )
            if SNP_HERIT_ACTIVE
            else []
        ),
        lambda wildcards: (
            expand(
                OUT_DIR / "{subset}" / "internal_pca_plink2.eigenvec",
                subset=["full"] + get_ancestries(wildcards),
            )
            if config.get("internalPCA", {}).get("method") == "plink2"
            else []
        ),
        lambda wildcards: (
            expand(
                OUT_DIR / "{subset}" / "internal_pca_plink2.eigenval",
                subset=["full"] + get_ancestries(wildcards),
            )
            if config.get("internalPCA", {}).get("method") == "plink2"
            else []
        ),


