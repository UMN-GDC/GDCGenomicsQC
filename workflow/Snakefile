rule assembleRef:
    input:
        ancient(REF / "1000G_highcoverage" / "population.txt"),
        ancient(REF / "1000G_highcoverage" / "pedigree.txt"),
        ancient(expand(
            REF
            / "1000G_highcoverage"
            / "1kGP_high_coverage_Illumina.chr{CHR}.filtered.SNV_INDEL_SV_phased_panel.vcf.gz",
            CHR=range(1, 23),
        )),
        ancient(REF / "1000G_highcoverage" / "1000G_highCoveragephased.pgen"),
        ancient(expand(REF / "gmaps" / "hg38map.chr{CHR}.txt", CHR=range(1, 23))),


rule run_initialQC:
    threads: 1
    resources:
        nodes=1,
        mem_mb=4000,
        runtime=60,
    input:
        lambda wildcards: (
            expand(OUT_DIR / "full" / "f1_{CHR}.pgen", CHR=CHROMOSOMES)
            if "{CHR}" in config.get("INPUT", "")
            else [OUT_DIR / "full" / "f1.pgen"]
        ),
        lambda wildcards: (
            expand(OUT_DIR / "full" / "f1.f2_{CHR}.pgen", CHR=CHROMOSOMES)
            if "{CHR}" in config.get("INPUT", "")
            else [OUT_DIR / "full" / "f1.b38.f2.pgen"]
        ),
        lambda wildcards: (
            expand(OUT_DIR / "full" / "initial_{CHR}.smiss", CHR=CHROMOSOMES)
            + expand(OUT_DIR / "full" / "initial_{CHR}.vmiss", CHR=CHROMOSOMES)
            + expand(OUT_DIR / "full" / "MAF_check_{CHR}.afreq", CHR=CHROMOSOMES)
            + expand(OUT_DIR / "full" / "standardFilter_{CHR}.hardy", CHR=CHROMOSOMES)
            if "{CHR}" in config.get("INPUT", "")
            else [
                OUT_DIR / "full" / "initial.smiss",
                OUT_DIR / "full" / "initial.vmiss",
                OUT_DIR / "full" / "MAF_check.afreq",
                OUT_DIR / "full" / "standardFilter.hardy",
            ]
        ),

rule run_pca:
    threads: 1
    resources:
        nodes=1,
        mem_mb=4000,
        runtime=420,  # 1 week
    input:
        labels=ancient(REF / "1000G_highcoverage" / "population.txt"),
        eigen_ref=OUT_DIR / "01-globalAncestry" / "refRefPCscores.sscore",
        eigen_sample=OUT_DIR / "01-globalAncestry" / "sampleRefPCscores.sscore",


