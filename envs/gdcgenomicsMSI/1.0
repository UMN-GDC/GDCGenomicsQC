#%Module######################################################################
#
#     GDC Genomics QC Pipeline module file
#     Sets up apptainer image cache for offline use
#

proc ModulesHelp { } {
    puts stderr "\tThis module loads the GDC Genomics QC Pipeline."
    puts stderr "\tIt sets up the apptainer image cache for offline use."
    puts stderr "\tIt also loads Snakemake for running the pipeline."
    puts stderr "\t"
    puts stderr "\tUsage: gdcgenomicsqc --configfile <config.yaml> [other snakemake options]"
    puts stderr "\t"
    puts stderr "\tThe gdcgenomicsqc command automatically adds --profile hpc"
    puts stderr "\tand --snakefile workflow/Snakefile, so users only need to specify"
    puts stderr "\tthe --configfile option."
}

# Activate conda and snakemake environment
set snakemake_env /projects/standard/gdc/public/envs/snakemake

# Add conda base and snakemake env to PATH
prepend-path PATH $snakemake_env/bin

set basedir [file dirname [info script]]
prepend-path PATH $basedir/bin

setenv SINGULARITY_TMPDIR /projects/standard/gdc/shared/singularity_tmp
setenv APPTAINER_TMPDIR /projects/standard/gdc/shared/singularity_tmp
setenv APPTAINER_CACHEDIR /projects/standard/gdc/shared/singularity_images
setenv SINGULARITY_CACHEDIR /projects/standard/gdc/shared/singularity_images
setenv SNAKEMAKE_APPTAINER_PREFIX /projects/standard/gdc/shared/singularity_images
setenv SNAKEMAKE_SINGULARITY_PREFIX /projects/standard/gdc/shared/singularity_images


