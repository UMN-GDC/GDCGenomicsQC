            )
        )(config.get("phenotypeSimulation", {}), config.get("phenotypeSimulation", {}).get("ancestries", [])) if (
            config.get("phenotypeSimulation", {}).get("enabled", False)
            and config.get("phenotypeSimulation", {}).get("ancestries", [])
            and config.get("phenotypeSimulation", {}).get("simulations", [])
        ) else [],


rule run_PCAinternal:
    threads: 1
    resources:
        nodes=1,
        mem_mb=4000,
        runtime=420,
    input:
        lambda wildcards: (
            lambda ancs: (
                (
                    expand(OUT_DIR / "{anc}" / "pcair_pcaobj.RDS", anc=ancs) +
                    expand(OUT_DIR / "{anc}" / "pcrelate_kinship.RDS", anc=ancs) +
                    expand(OUT_DIR / "{anc}" / "pcair_coordinates.tsv", anc=ancs)
                    if config.get("internalPCA", {}).get("method", "plink2") in ["pcair", "both"]
                    else []
                ) + (
                    expand(OUT_DIR / "{anc}" / "internal_pca_plink2.eigenvec", anc=ancs) +
                    expand(OUT_DIR / "{anc}" / "internal_pca_plink2.eigenval", anc=ancs)
                    if config.get("internalPCA", {}).get("method", "plink2") in ["plink2", "both"]
                    else []
                )
            )
        )(get_ancestries(wildcards) + ["full"]),


