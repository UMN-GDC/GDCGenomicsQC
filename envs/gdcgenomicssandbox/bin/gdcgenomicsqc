#!/bin/bash
# Wrapper for snakemake that uses GDC Genomics QC defaults (Sandbox)
# Usage: gdcgenomicsqc [SNAKEMAKE_ARGS...]
#
# This wrapper adds:
#   --profile profiles/sandbox
#   --snakefile workflow/Snakefile
# Users only need to specify --configfile

WORKFLOW_DIR=/scratch.global/GDC/GDCGenomicsQC

exec snakemake --profile "$WORKFLOW_DIR/profiles/sandbox" --snakefile "$WORKFLOW_DIR/workflow/Snakefile" "$@"