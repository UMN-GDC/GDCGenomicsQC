Bootstrap: docker
From: mambaorg/micromamba:latest

%arguments
    # Best practice: Name your environment something consistent
    ENV_NAME=mash


%environment
    export MAMBA_ROOT_PREFIX=/opt/conda
    export PATH="/opt/conda/envs/{{ ENV_NAME }}/bin:/opt/conda/bin:$PATH"
    export LC_ALL=C.UTF-8

%files
    mash.yml /app/mash.yml

%post
    /usr/bin/micromamba create -y -n {{ ENV_NAME }} -f /app/mash.yml
    /usr/bin/micromamba clean --all -y

%runscript
    # This runs when you execute the container file directly
    echo "Container ready."
    echo "Available commands: 'MASH' and 'SimulateMASH'"
    exec "$@"

%labels
    Author Christian Coffman
    Version v1.0.0

