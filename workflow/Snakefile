OUT_DIR = Path(config['OUT_DIR'])
REF = Path(config['REF'])

def get_ancestries(wildcards):
    # Wait for the PCArelate checkpoint and get the 'ancestry' output file
    ancestry_file = checkpoints.estimateAncestry.get(subset="full").output.ancestry
    return pd.read_csv(ancestry_file, sep="\t").pc_label.dropna().unique().tolist()


def get_ancestry_file(wildcards):
    """
    If the subset is 'full', return an empty list (no dependency).
    Otherwise, return the path to the estimated ancestry file.
    """
    if wildcards.subset == "full":
        return [] 
    else:
        return checkpoints.estimateAncestry.get(subset="full").output.ancestry
    


