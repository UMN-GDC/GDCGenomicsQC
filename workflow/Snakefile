report: "../report/stylesheet.css"


# Paths in include and configfile are relative to the Snakefile
# paths inside the rules are relative to where you run the command.

CHROMOSOMES = config.get("chromosomes", list(range(1, 23)))

def input_is_per_chromosome():
    return "{CHR}" in config.get("INPUT", "")


checkpoint detectInputPattern:
    output:
        touch(OUT_DIR / ".input_pattern_detected")
    run:
        if input_is_per_chromosome():
            print(f"Input is per-chromosome: {config.get('INPUT', '')}")
        else:
            print(f"Input is single file: {config.get('INPUT', '')}")


