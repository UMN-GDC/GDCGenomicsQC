rule all:
    threads: 1
    resources:
        nodes = 1,
        mem_mb = 4000,
        runtime = 420 # 1 week
    input:
        expand(OUT_DIR / "{ANCESTRY}" / "initialFilter_{CHR}.pgen", ANCESTRY= ANCESTRIES, CHR = CHROMOSOMES),
        expand(OUT_DIR / "{ANCESTRY}" / "initialFilter.bed", ANCESTRY= ANCESTRIES),
        expand(OUT_DIR / "{ANCESTRY}" / "standardFilter.bed", ANCESTRY= ANCESTRIES),
        OUT_DIR / "full" / "unrelated.bed",
        expand(OUT_DIR / "{ANCESTRY}" / "unrelated.bed", ANCESTRY= ANCESTRIES)

rule assembleRef: 
    input:
        REF / "1000G_highcoverage" / "population.txt",
        REF / "1000G_highcoverage" / "pedigree.txt",
        expand(REF / "1000G_highcoverage" / "1kGP_high_coverage_Illumina.chr{CHR}.filtered.SNV_INDEL_SV_phased_panel.vcf.gz", CHR = CHROMOSOMES)

rule run_initialQC:
    threads: 1
    resources:
        nodes = 1,
        mem_mb = 4000,
        runtime = 60
    input:
        #expand(OUT_DIR / "full" / "initialFilter_{CHR}.pgen", CHR=CHROMOSOMES),
        OUT_DIR / "full" / "standardFilter.bed",
