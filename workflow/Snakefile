checkpoint assembleRef:
    input:
        REF / "1000G_highcoverage" / "population.txt",
        REF / "1000G_highcoverage" / "pedigree.txt",
        expand(
            REF
            / "1000G_highcoverage"
            / "1kGP_high_coverage_Illumina.chr{CHR}.filtered.SNV_INDEL_SV_phased_panel.vcf.gz",
            CHR=range(1, 23),
        ),
        REF / "1000G_highcoverage" / "1000G_highCoveragephased.pgen",
        expand(REF / "gmaps" / "chr{CHR}.b38.gmap.rfmix.gz", CHR=range(1, 23)),


rule run_initialQC:
    threads: 1
    resources:
        nodes=1,
        mem_mb=4000,
        runtime=60,
    input:
        expand(OUT_DIR / "full" / "initialFilter_{CHR}.pgen", CHR=CHROMOSOMES),
        OUT_DIR / "full" / "standardFilter.pgen",
        OUT_DIR / "full" / "initialFilter.pgen",
        OUT_DIR / "full" / "figures" / "smiss.svg",
        OUT_DIR / "full" / "figures" / "vmiss.svg",


rule run_pca:
    threads: 1
    resources:
        nodes=1,
        mem_mb=4000,
        runtime=420,  # 1 week
    input:
        labels=REF / "1000G_highcoverage" / "population.txt",
        eigen_ref=OUT_DIR / "01-globalAncestry" / "refRefPCscores.sscore",
        eigen_sample=OUT_DIR / "01-globalAncestry" / "sampleRefPCscores.sscore",


rule run_estimateAdmixing:
    threads: 1
    resources:
        nodes=1,
        mem_mb=4000,
        runtime=420,  # 1 week
    input:
        labels=REF / "1000G_highcoverage" / "population.txt",
        eigen_ref=OUT_DIR / "01-globalAncestry" / "refRefPCscores.sscore",
        eigen_sample=OUT_DIR / "01-globalAncestry" / "sampleRefPCscores.sscore",
        umap_ref=OUT_DIR / "01-globalAncestry" / "umap_ref.csv",
        umap_sample=OUT_DIR / "01-globalAncestry" / "umap_sample.csv",
        rfmix_global=OUT_DIR / "02-localAncestry" / "ancestry_full.txt",


rule run_classifyAncestry:
    threads: 1
    resources:
        nodes=1,
        mem_mb=4000,
        runtime=420,  # 1 week
    input:
        OUT_DIR / "02-localAncestry" / "ancestry_full.txt",
        OUT_DIR / "01-globalAncestry" / "posterior_probabilities.tsv",
        OUT_DIR
        / "01-globalAncestry"
        / f"posterior_probability_stacked_{ANCESTRY_MODEL}.svg",


rule run_ancestryQC:
    threads: 1
    resources:
        nodes=1,
        mem_mb=4000,
        runtime=420,  # 1 week
    input:
        lambda wildcards: expand(
            OUT_DIR / "{ANCESTRY}" / "initialFilter_{CHR}.pgen",
            ANCESTRY=get_ancestries(wildcards),
            CHR=CHROMOSOMES,
        ),
        lambda wildcards: expand(
            OUT_DIR / "{ANCESTRY}" / "initialFilter.pgen",
            ANCESTRY=get_ancestries(wildcards),
        ),
        lambda wildcards: expand(
            OUT_DIR / "{ANCESTRY}" / "standardFilter.pgen",
            ANCESTRY=get_ancestries(wildcards),
        ),


rule run_relatedness:
    threads: 1
    resources:
        nodes=1,
        mem_mb=4000,
        runtime=420,  # 1 week
    input:
        OUT_DIR / "full" / "unrelated.pgen",
        lambda wildcards: expand(
            OUT_DIR / "{ANCESTRY}" / "unrelated.pgen",
            ANCESTRY=get_ancestries(wildcards),
        ),


rule run_rfmix:
    threads: 1
    resources:
        nodes=1,
        mem_mb=4000,
        runtime=420,  # 1 week
    input:
        expand(OUT_DIR / "02-localAncestry" / "chr{CHR}.phased.vcf.gz", CHR=LOCAL_ANCESTRY_CHROMOSOMES),
        expand(OUT_DIR / "02-localAncestry" / "chr{CHR}.lai.msp.tsv", CHR=LOCAL_ANCESTRY_CHROMOSOMES),


rule run_simulatePhenotype:
    threads: 1
    resources:
        nodes=1,
        mem_mb=4000,
        runtime=420,
    input:
        lambda wildcards: expand(
            OUT_DIR
            / "simulations"
            / f"{config.get('phenotypeSimulation', {}).get('ancestries', ['AFR', 'EUR'])[0]}_{config.get('phenotypeSimulation', {}).get('ancestries', ['AFR', 'EUR'])[1]}"
            / "{anc}_simulation_pheno1.estimates",
            anc=config.get("phenotypeSimulation", {}).get("ancestries", ["AFR", "EUR"]),
        ),


