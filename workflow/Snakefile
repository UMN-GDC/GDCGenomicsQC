rule all:
    input:
        expand(
            OUT_DIR / "01-globalAncestry" / "keep_{ANC}.txt", ANC=get_provided_ancestries()
        ) if has_provided_ancestry() else [],
        lambda wildcards: (
            [OUT_DIR / "01-globalAncestry" / "refRefPCscores.sscore",
             OUT_DIR / "01-globalAncestry" / "sampleRefPCscores.sscore",
             OUT_DIR / "01-globalAncestry" / "umap_sample.csv",
             OUT_DIR / "01-globalAncestry" / "umap_ref.csv",
             OUT_DIR / "01-globalAncestry" / "ancestry_classifications.tsv"]
            if not has_provided_ancestry() else []
        ),
        lambda wildcards: (
            [OUT_DIR / "02-localAncestry" / "ancestry_full.txt"] +
            expand(OUT_DIR / "02-localAncestry" / "chr{CHR}.lai.msp.tsv", CHR=LOCAL_ANCESTRY_CHROMOSOMES)
            if (not has_provided_ancestry() and uses_rfmix()) else []
        ),
        lambda wildcards: (
            expand(
                OUT_DIR / "{ANC}" / ("f1_{CHR}.pgen" if INPUT_IS_PER_CHROMOSOME else "f1.pgen"),
                ANC=get_provided_ancestries(), CHR=CHROMOSOMES,
            )
            if has_provided_ancestry() else 
            expand(
                OUT_DIR / "full" / ("f1_{CHR}.pgen" if INPUT_IS_PER_CHROMOSOME else "f1.pgen"),
                CHR=CHROMOSOMES,
            )
        ),
        lambda wildcards: (
            expand(
                OUT_DIR / "{ANC}" / "f1.f2_{CHR}.pgen",
                ANC=get_provided_ancestries(), CHR=CHROMOSOMES,
            )
            if (has_provided_ancestry() and INPUT_IS_PER_CHROMOSOME)
            else expand(
                OUT_DIR / "{ANC}" / "f1.b38.f2.pgen", ANC=get_provided_ancestries()
            ) if has_provided_ancestry() else (
                expand(OUT_DIR / "full" / "f1.f2_{CHR}.pgen", CHR=CHROMOSOMES)
                if INPUT_IS_PER_CHROMOSOME
                else expand(OUT_DIR / "full" / "f1.b38.f2.pgen")
            )
        ),


if input_is_per_chromosome():
    ruleorder: convertPlinkPerChromosome > concatLdPruned
    ruleorder: convertPlinkPerChromosome > concatPgen
else:
    ruleorder: convertPlinkSingleFile
ruleorder: convertPgenToVcf > compressAndIndexVcf

