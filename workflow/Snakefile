rule all:
    threads: 1
    resources:
        nodes = 1,
        mem_mb = 4000,
        runtime = 420 # 1 week
    input:
        lambda wildcards: expand(OUT_DIR / "{ANCESTRY}" / "initialFilter_{CHR}.pgen", ANCESTRY=get_ancestries(wildcards), CHR = CHROMOSOMES),
        lambda wildcards: expand(OUT_DIR / "{ANCESTRY}" / "initialFilter.bed", ANCESTRY= get_ancestries(wildcards)),
        lambda wildcards: expand(OUT_DIR / "{ANCESTRY}" / "standardFilter.bed", ANCESTRY= get_ancestries(wildcards)),
        lambda wildcards: expand(OUT_DIR / "{ANCESTRY}" / "unrelated.bed", ANCESTRY= get_ancestries(wildcards)),
        OUT_DIR / "full" / "standardFilter.bed",
        OUT_DIR / "full" / "unrelated.bed",

checkpoint assembleRef:
    input:
        REF / "1000G_highcoverage" / "population.txt",
        REF / "1000G_highcoverage" / "pedigree.txt",
        expand(REF / "1000G_highcoverage" / "1kGP_high_coverage_Illumina.chr{CHR}.filtered.SNV_INDEL_SV_phased_panel.vcf.gz", CHR = CHROMOSOMES),
        REF / "1000G_highcoverage" / "1000G_highCoveragephased.bed",

rule run_initialQC:
    threads: 1
    resources:
        nodes = 1,
        mem_mb = 4000,
        runtime = 60
    input:
