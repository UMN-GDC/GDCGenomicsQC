#%Module######################################################################
#
#     GDC Genomics QC Pipeline - Sandbox Module
#     For sandbox/local HPC use with fixed paths
#

proc ModulesHelp { } {
    puts stderr "\tThis module loads the GDC Genomics QC Pipeline (Sandbox)."
    puts stderr "\tIt sets up the apptainer image cache and paths for sandbox use."
    puts stderr "\t"
    puts stderr "\tUsage: gdcgenomicsqc --configfile <config.yaml> [other snakemake options]"
    puts stderr "\t"
    puts stderr "\tThe gdcgenomicsqc command automatically adds --profile sandbox"
    puts stderr "\tand --snakefile workflow/Snakefile, so users only need to specify"
    puts stderr "\tthe --configfile option."
}


set basedir /scratch.global/coffm049/GDCGenomicsQC/envs/gdcgenomicssandbox
set workflowdir /scratch.global/GDC/GDCGenomicsQC

prepend-path PATH $basedir/bin
setenv APPTAINER_CACHEDIR /scratch.global/GDC/singularityimages
setenv SNAKEMAKE_APPTAINER_PREFIX /scratch.global/GDC/singularityimages
setenv SNAKEMAKE_WORKDIR /scratch.global/GDC/GDCGenomicsQC