# Paths in include and configfile are relative to the Snakefile
# paths inside the rules are relative to where you run the command.

CHROMOSOMES = config.get("chromosomes", list(range(1, 23)))
CHR_REGEX = "|".join(str(c) for c in CHROMOSOMES)

wildcard_constraints:
    CHR=CHR_REGEX

def input_is_per_chromosome():
    return "{CHR}" in config.get("INPUT", "")

OUT_DIR = Path(config.get("OUT_DIR", "/path/to/out"))
REF = Path(config.get("REF", "/path/to/ref"))
STORAGE_PREFIX = Path(os.path.abspath(config.get("local-storage-prefix", "/tmp")))
ANCESTRY_MODEL = config.get("ancestry", {}).get("model", "pca")

SCRIPTS_DIR = (Path(workflow.basedir) / "scripts").resolve()

ruleorder: convertPgenToVcf > compressAndIndexVcf
ruleorder: createProvidedAncestryKeepFiles > classifySamplesByAncestry


